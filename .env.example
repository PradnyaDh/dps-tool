# Copy this file to .env and fill in your values
# cp .env.example .env

# Atlassian session cookie (Confluence + Jira)
# Get from browser DevTools → Application → Cookies → cloud.session.token
# Refresh every ~30 days when it expires
CONF_COOKIE="cloud.session.token=eyJ..."

# Slack (optional) — set either one to enable Slack summaries
SLACK_WEBHOOK_URL=""   # preferred: ask your Slack admin for a webhook URL
SLACK_TOKEN=""         # alternative: bot token (xoxb-...)
